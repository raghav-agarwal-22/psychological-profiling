# ─── Web (Vercel) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.innermindhealing.com
NEXT_PUBLIC_WEB_URL=https://innermindhealing.com

# ─── API (Railway) ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...
JWT_SECRET=<random-64-char-hex>
MAGIC_LINK_SECRET=<random-64-char-hex>
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@innermindhealing.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
ADMIN_SECRET=<random-32-char-hex>
CRON_SECRET=<random-32-char-hex>

# WEB_URL is used by the API to build magic link URLs and set CORS origin
WEB_URL=https://innermindhealing.com

# Runtime
NODE_ENV=production
API_PORT=3000
API_HOST=0.0.0.0

# ─── Optional ─────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
