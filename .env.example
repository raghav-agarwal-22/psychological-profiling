# Database
DATABASE_URL="postgresql://innermind:innermind_dev@localhost:5432/innermind_dev"
DATABASE_URL_TEST="postgresql://innermind:innermind_dev@localhost:5433/innermind_test"

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
MAGIC_LINK_SECRET=your-magic-link-secret-change-in-production

# Resend (email delivery)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@innermind.app
# Set to "true" to skip email sending and log magic links to console (local dev)
SKIP_EMAIL=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cron (protects /api/drip/process — set to any random secret)
CRON_SECRET=your-cron-secret-change-in-production

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
