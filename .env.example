# Database
DATABASE_URL="postgresql://innermind:innermind_dev@localhost:5432/innermind_dev"
DATABASE_URL_TEST="postgresql://innermind:innermind_dev@localhost:5433/innermind_test"

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
MAGIC_LINK_SECRET=your-magic-link-secret-change-in-production

# Resend (email delivery)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@innermindhealing.com
# Set to "true" to skip email sending and log magic links to console (local dev)
SKIP_EMAIL=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cron (protects /api/drip/process — set to any random secret)
CRON_SECRET=your-cron-secret-change-in-production

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Stripe Billing ────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION — server throws at startup if these are missing or placeholder

# Secret API key: use sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe Dashboard → Webhooks (whsec_...)
# Required to verify incoming webhook payloads; never skip in any environment
STRIPE_WEBHOOK_SECRET=whsec_...

# Consumer (individual) plan price IDs — differ between test and live mode
# Dashboard → Products → find your Pro plan → copy Price ID
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Professional (B2B) plan price IDs
STRIPE_PROFESSIONAL_STARTER_MONTHLY=price_...
STRIPE_PROFESSIONAL_STARTER_ANNUAL=price_...
STRIPE_PROFESSIONAL_UNLIMITED_MONTHLY=price_...
STRIPE_PROFESSIONAL_UNLIMITED_ANNUAL=price_...

# Optional: coupon ID for the cancellation-save retention discount (50% off)
STRIPE_RETENTION_COUPON_ID=

# Optional: Slack webhook URL for first-paying-customer milestone alerts
SLACK_WEBHOOK_URL=
