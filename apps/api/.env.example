# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://innermind:innermind_dev@localhost:5432/innermind_dev"
DATABASE_URL_TEST="postgresql://innermind:innermind_dev@localhost:5433/innermind_test"

# ─── Server ───────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
WEB_URL=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
MAGIC_LINK_SECRET=your-magic-link-secret-change-in-production

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@innermindhealing.com
# Set to "true" to skip sending emails and log magic links to stdout in local dev
SKIP_EMAIL=true

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Cron protection ──────────────────────────────────────────────────────────
# Protects /api/drip/process and /api/billing/trial-reminders
CRON_SECRET=your-cron-secret-change-in-production
DIGEST_SECRET=your-digest-secret-change-in-production

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: the API throws at startup if any value is missing or
# still set to a placeholder in NODE_ENV=production.
#
# Secret API key — use sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe Dashboard → Webhooks (whsec_...)
# Signature verification is always enforced; never bypass in any environment
STRIPE_WEBHOOK_SECRET=whsec_...

# Consumer (individual) plan price IDs — IDs differ between Stripe test and live mode
# Stripe Dashboard → Products → Pro plan → copy Price ID for each price
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Professional (B2B) workspace plan price IDs
STRIPE_PROFESSIONAL_STARTER_MONTHLY=price_...
STRIPE_PROFESSIONAL_STARTER_ANNUAL=price_...
STRIPE_PROFESSIONAL_UNLIMITED_MONTHLY=price_...
STRIPE_PROFESSIONAL_UNLIMITED_ANNUAL=price_...

# Optional: coupon ID for the cancellation-save retention discount (50% off)
STRIPE_RETENTION_COUPON_ID=

# Optional: Slack webhook URL for first-paying-customer milestone notifications
SLACK_WEBHOOK_URL=

# ─── Analytics (PostHog) — optional, set on web but may be read by API ───────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
