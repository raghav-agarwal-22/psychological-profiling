// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  timezone  String   @default("UTC")
  locale    String   @default("en")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // AI synthesis (cross-framework narrative)
  synthesis            String?   @map("synthesis")
  synthesisGeneratedAt DateTime? @map("synthesis_generated_at")

  // AI growth recommendations
  growthRecommendations          Json?     @map("growth_recommendations")
  recommendationsGeneratedAt     DateTime? @map("recommendations_generated_at")

  // Email digest
  emailDigestOptIn     Boolean   @default(true) @map("email_digest_opt_in")
  lastDigestSentAt     DateTime? @map("last_digest_sent_at")

  // Subscription
  subscriptionTier      String    @default("free") @map("subscription_tier") // free | essential | pro
  subscriptionInterval  String?   @map("subscription_interval") // monthly | annual | null
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  trialEndsAt           DateTime? @map("trial_ends_at")
  firstPaidAt           DateTime? @map("first_paid_at")

  // Acquisition attribution
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")

  // Auth
  magicLinkTokens MagicLinkToken[]

  // Core relationships
  sessions           Session[]
  profiles           Profile[]
  assessments        Assessment[]
  insights           Insight[]
  journalEntries     JournalEntry[]
  coachConversations CoachConversation[]
  dailyPrompts       DailyPrompt[]

  // Teams
  ownedTeams      Team[]       @relation("TeamOwner")
  teamMemberships TeamMember[]

  // Referrals
  referralsSent    Referral[] @relation("ReferralsSent")
  referralReceived Referral?  @relation("ReferralReceived")
  referralCode     String?    @unique @map("referral_code")
  referredByCode   String?    @map("referred_by_code")

  // Onboarding email tracking
  onboardingEmails OnboardingEmail[]

  // Testimonial
  testimonial Testimonial?

  @@map("users")
}

// ─── OnboardingEmail ─────────────────────────────────────────────────────────
// Tracks which onboarding emails have been sent to each user.

model OnboardingEmail {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  emailType String   @map("email_type") // welcome | assessment_nudge | profile_reveal | deep_dive | pro_upgrade
  sentAt    DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType])
  @@index([userId])
  @@map("onboarding_emails")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("magic_link_tokens")
}

// ─── Session ─────────────────────────────────────────────────────────────────
// An assessment session — a single sitting of answering questions.
// A user may have multiple sessions over time (longitudinal tracking).

model Session {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  title       String?
  status      SessionStatus @default(IN_PROGRESS)
  contextTags String[]      @default([]) @map("context_tags")
  startedAt   DateTime      @default(now()) @map("started_at")
  completedAt DateTime?     @map("completed_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments Assessment[]

  @@index([userId])
  @@index([userId, completedAt])
  @@map("sessions")
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

// ─── AssessmentTemplate ───────────────────────────────────────────────────────
// A reusable blueprint for an assessment instrument.
// Stores the canonical question bank and scoring config for a given type/version.

model AssessmentTemplate {
  id            String         @id @default(cuid())
  type          AssessmentType
  version       String         @default("1.0")
  title         String
  description   String?
  questionBank  Json           @map("question_bank")
  // Array of: { id, text, dimension, reverse_scored }
  scoringConfig Json           @map("scoring_config")
  // Per-dimension: { questionIds, reverseIds, formula ("average"), normalize }
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  assessments Assessment[]

  @@unique([type, version])
  @@map("assessment_templates")
}

// ─── Assessment ──────────────────────────────────────────────────────────────
// A single assessment instrument within a session.
// Could be a personality test, values inventory, shadow work prompt, etc.

model Assessment {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  sessionId    String           @map("session_id")
  templateId   String?          @map("template_id")
  type         AssessmentType
  title        String
  description  String?
  status       AssessmentStatus @default(NOT_STARTED)
  currentStep  Int              @default(0) @map("current_step")
  totalSteps   Int?             @map("total_steps")
  rawResponses Json             @default("{}") @map("raw_responses")
  metadata     Json             @default("{}")
  startedAt    DateTime?        @map("started_at")
  completedAt  DateTime?        @map("completed_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template  AssessmentTemplate? @relation(fields: [templateId], references: [id])
  insights  Insight[]
  responses AssessmentResponse[]

  @@index([userId])
  @@index([sessionId])
  @@index([templateId])
  @@map("assessments")
}

// ─── AssessmentResponse ───────────────────────────────────────────────────────
// Individual question-level response for a structured assessment.
// Supports Likert-scale (1-5) responses with reverse scoring applied at scoring time.

model AssessmentResponse {
  id           String     @id @default(cuid())
  assessmentId String     @map("assessment_id")
  questionId   String     @map("question_id")
  value        Int        // Likert 1-5 (raw; reverse scoring applied during score computation)
  createdAt    DateTime   @default(now()) @map("created_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("assessment_responses")
}

enum AssessmentType {
  BIG_FIVE              // Big Five personality traits
  JUNGIAN_ARCHETYPES    // Jungian archetypes / MBTI-adjacent
  VALUES_INVENTORY      // Personal values elicitation
  SHADOW_WORK           // Shadow / blind spot exploration
  LIFE_SATISFACTION     // Life domain satisfaction mapping
  STRENGTHS             // Strengths-based assessment
  ATTACHMENT_STYLE      // Attachment style
  ENNEAGRAM             // Enneagram 9 types with wing identification
  LIGHT_DARK_TRIAD      // Light Triad (humanism, Kantianism, faith) + Dark Triad (narcissism, Machiavellianism, psychopathy)
  CUSTOM                // AI-generated adaptive assessment
}

enum AssessmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ─── Profile ─────────────────────────────────────────────────────────────────
// A synthesized psychological profile derived from one or more assessments.
// Profiles are versioned — each new assessment can produce a new profile revision.

model Profile {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  version     Int         @default(1)
  isLatest    Boolean     @default(true) @map("is_latest")
  summary     String      // Plain-language summary of the profile
  dimensions  Json        // Scored dimensions (e.g., {openness: 0.82, conscientiousness: 0.65})
  archetypes  Json        @default("[]") // Dominant Jungian archetypes
  values      Json        @default("[]") // Core identified values
  blindSpots  Json        @default("[]") @map("blind_spots") // Shadow / blind spots
  strengths   Json        @default("[]")
  rawOutput   Json        @map("raw_output") // Full Claude output before structuring
  generatedAt DateTime    @default(now()) @map("generated_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  isPublic    Boolean   @default(false) @map("is_public")
  shareToken  String?   @unique @map("share_token")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights       Insight[]
  journalEntries JournalEntry[]

  @@index([userId])
  @@index([userId, isLatest])
  @@index([shareToken])
  @@map("profiles")
}

// ─── Insight ─────────────────────────────────────────────────────────────────
// A specific, actionable insight surfaced from the profile or assessment.
// Insights are the primary unit of value delivered to the user.

model Insight {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  profileId    String?     @map("profile_id")
  assessmentId String?     @map("assessment_id")
  type         InsightType
  title        String
  body         String      // The insight content (markdown)
  symbol       String?     // Optional symbolic/archetypal reference
  domain       LifeDomain?
  isRead       Boolean     @default(false) @map("is_read")
  isSaved      Boolean     @default(false) @map("is_saved")
  reactions    Json        @default("{}") // User reactions / ratings
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    Profile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, domain])
  @@map("insights")
}

enum InsightType {
  PATTERN          // Recurring behavioral/emotional pattern
  STRENGTH         // Identified strength or gift
  BLIND_SPOT       // Shadow / unconscious pattern
  VALUE_ALIGNMENT  // Where actions align with values
  VALUE_CONFLICT   // Where actions conflict with values
  ARCHETYPE        // Dominant archetype manifestation
  GROWTH_EDGE      // Area for conscious development
  REFLECTION       // Open-ended reflection prompt
}

enum LifeDomain {
  WORK
  RELATIONSHIPS
  HEALTH
  CREATIVITY
  MEANING
  FINANCES
  FAMILY
  PERSONAL_GROWTH
}

// ─── CoachConversation ───────────────────────────────────────────────────────
// A saved conversation thread with the AI coach.

model CoachConversation {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  title     String?        // Auto-generated from first message
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId])
  @@map("coach_conversations")
}

// ─── CoachMessage ─────────────────────────────────────────────────────────────
// A single message in a coach conversation.

model CoachMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("coach_messages")
}

// ─── DailyPrompt ─────────────────────────────────────────────────────────────
// A personalized daily reflection prompt for a user.

model DailyPrompt {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  date      String    // YYYY-MM-DD in user's timezone
  prompt    String
  response  String?   // User's journal response, if any
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_prompts")
}

// ─── JournalEntry ────────────────────────────────────────────────────────────
// Free-form reflections tied to insights or standalone.

model JournalEntry {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  profileId String?   @map("profile_id")
  insightId String?   @map("insight_id")
  prompt    String?   // The reflection prompt this entry responded to
  title     String?
  body      String
  mood      Int?      // 1-10 mood score at time of writing
  tags      String[]  @default([])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([profileId])
  @@map("journal_entries")
}

// ─── Team ─────────────────────────────────────────────────────────────────────
// Repurposed as a practitioner workspace for the Professional tier.
// type: "professional" = coach/therapist workspace with client management

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  ownerId     String   @map("owner_id")
  owner       User     @relation("TeamOwner", fields: [ownerId], references: [id])
  members     TeamMember[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Workspace type
  type             String   @default("professional") @map("type") // "professional"
  seatLimit        Int      @default(3) @map("seat_limit")
  professionalTier String   @default("starter") @map("professional_tier") // "starter" | "unlimited"

  // Trial
  trialEndsAt DateTime? @map("trial_ends_at")

  // Stripe subscription
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  subscriptionStatus   String   @default("inactive") @map("subscription_status") // "inactive" | "trial" | "active" | "cancelled"

  @@map("teams")
}

// ─── TeamMember ───────────────────────────────────────────────────────────────

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  userId   String?  @map("user_id") // null until client accepts invite
  role     String   @default("client") @map("role") // "owner" | "client"
  joinedAt DateTime @default(now()) @map("joined_at")

  // Client invite fields
  inviteToken       String?   @unique @map("invite_token")
  inviteEmail       String?   @map("invite_email")
  inviteStatus      String    @default("pending") @map("invite_status") // "pending" | "accepted"
  invitedAt         DateTime? @map("invited_at")
  practitionerNotes String?   @map("practitioner_notes") @db.Text

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

// ─── Affiliate Program ────────────────────────────────────────────────────────

model Affiliate {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  websiteUrl      String    @map("website_url")
  audienceDesc    String    @map("audience_desc")
  audienceSize    Int?      @map("audience_size")
  status          String    @default("pending") // pending | approved | rejected
  referralCode    String    @unique @map("referral_code")
  userId          String?   @unique @map("user_id") // if they're also a registered user
  totalClicks     Int       @default(0) @map("total_clicks")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  referrals       AffiliateReferral[]
  commissions     AffiliateCommission[]

  @@map("affiliates")
}

model AffiliateReferral {
  id            String    @id @default(cuid())
  affiliateId   String    @map("affiliate_id")
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id])
  userId        String    @unique @map("user_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  commissions   AffiliateCommission[]

  @@index([affiliateId])
  @@map("affiliate_referrals")
}

model AffiliateCommission {
  id              String    @id @default(cuid())
  affiliateId     String    @map("affiliate_id")
  affiliate       Affiliate @relation(fields: [affiliateId], references: [id])
  referralId      String    @map("referral_id")
  referral        AffiliateReferral @relation(fields: [referralId], references: [id])
  amountCents     Int       @map("amount_cents") // commission in cents (e.g. 240 = $2.40)
  status          String    @default("pending") // pending | paid
  stripeInvoiceId String?   @unique @map("stripe_invoice_id")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([affiliateId])
  @@index([referralId])
  @@map("affiliate_commissions")
}

// ─── AnonymousSession ─────────────────────────────────────────────────────────
// Temporary store for anonymous assessment flow (before email capture).
// Expires after 24h. Claimed once user provides their email.

model AnonymousSession {
  id              String    @id @default(cuid())
  guestToken      String    @unique @map("guest_token")
  templateId      String    @map("template_id")
  templateType    String    @map("template_type")
  profileJson     Json?     @map("profile_json")     // null until complete
  archetypeName   String?   @map("archetype_name")   // first archetype for teaser
  claimedByUserId String?   @unique @map("claimed_by_user_id")
  referralCode    String?   @map("referral_code")
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([guestToken])
  @@map("anonymous_sessions")
}

// ─── Referral ─────────────────────────────────────────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  referrerId      String    @map("referrer_id")
  referrer        User      @relation("ReferralsSent", fields: [referrerId], references: [id])
  referredEmail   String?   @map("referred_email")
  referredUserId  String?   @unique @map("referred_user_id")
  referredUser    User?     @relation("ReferralReceived", fields: [referredUserId], references: [id])
  status          String    @default("pending") // pending | completed | rewarded
  rewardGranted   Boolean   @default(false) @map("reward_granted")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  @@index([referrerId])
  @@map("referrals")
}

// ─── Testimonial ──────────────────────────────────────────────────────────────
// User-submitted testimonials collected after they view their full profile.
// Auto-approved for 4+ star ratings. Featured testimonials appear on landing + upgrade pages.

model Testimonial {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")   // one per user
  firstName      String   @map("first_name")        // first name only for privacy
  personalityTag String?  @map("personality_tag")   // e.g. "INFJ • Enneagram 4"
  rating         Int                                 // 1–5
  quote          String
  isApproved     Boolean  @default(false) @map("is_approved")
  isFeatured     Boolean  @default(false) @map("is_featured")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isApproved, rating])
  @@map("testimonials")
}

// ─── NotifyList ───────────────────────────────────────────────────────────────
// Pre-launch email capture — people who want to be notified on Product Hunt day.

model NotifyList {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("prelaunch_notify")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notify_list")
}
